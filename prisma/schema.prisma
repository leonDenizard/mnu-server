generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

/// =================
/// STORE DOMAIN
/// =================

enum DocumentType {
  CPF
  CNPJ
}

enum StoreStatus {
  ACTIVE
  SUSPENDED
  BLOCKED
}

enum Weekday {
  SUNDAY
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
}

model Store {
  id           String       @id @default(uuid())
  name         String
  slug         String       @unique @db.Citext()
  document     String       @unique
  documentType DocumentType
  legalName    String?
  status       StoreStatus  @default(ACTIVE)

  phone    String?
  whatsapp String?

  addressLine   String?
  addressNumber String?
  neighborhood  String?
  city          String?
  state         String?
  zipCode       String?

  latitude  Decimal? @db.Decimal(9, 6)
  longitude Decimal? @db.Decimal(9, 6)

  isOpen Boolean @default(true)

  supportsDelivery Boolean @default(true)
  supportsPickup   Boolean @default(true)
  supportsDineIn   Boolean @default(false)

  deliveryRadiusKm Decimal? @db.Decimal(5, 2)
  deliveryFeeCents Int?

  trialEndsAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users          User[]
  categories     Category[]
  products       Product[]
  operatingHours StoreOperatingHour[]
}

/// =================
/// STORE StoreOperatingHour
/// =================

model StoreOperatingHour {
  id        String  @id @default(uuid())
  weekday   Weekday
  openTime  String
  closeTime String

  storeId String
  store   Store  @relation(fields: [storeId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([storeId])
  @@index([storeId, weekday])
}

/// =================
/// STORE user
/// =================
enum Role {
  OWNER
  STAFF
}

model User {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  passwordHash String
  role         Role
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  storeId String
  store   Store  @relation(fields: [storeId], references: [id])

  @@unique([email, storeId])
  @@index([storeId])
}

/// =================
/// STORE Menu
/// =================

model Category {
  id     String  @id @default(uuid())
  title  String
  active Boolean @default(true)

  displayOrder Int     @default(0)
  showInMenu   Boolean @default(true)
  showInPos    Boolean @default(false)
  showInWaiter Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  storeId String
  store   Store     @relation(fields: [storeId], references: [id], onDelete: Cascade)
  product Product[]

  @@unique([storeId, title])
  @@index([storeId])
  @@index([storeId, displayOrder])
}

model Product {
  id               String   @id @default(uuid())
  name             String
  price            Decimal  @db.Decimal(10, 2)
  description      String?
  image            String?
  promotionalPrice Decimal? @db.Decimal(10, 2)
  active           Boolean  @default(true)
  displayOrder     Int      @default(0)
  categoryId       String
  storeId          String
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  store    Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([storeId, categoryId, name])
  @@index([storeId])
  @@index([storeId, displayOrder])
}
