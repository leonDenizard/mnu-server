generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

/// =================
/// STORE DOMAIN
/// =================

enum DocumentType {
  CPF
  CNPJ
}

enum StoreStatus {
  ACTIVE
  SUSPENDED
  BLOCKED
}

enum Weekday {
  SUNDAY
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
}

model Store {
  id           String       @id @default(uuid())
  name         String
  slug         String       @unique @db.Citext()
  document     String       @unique
  documentType DocumentType
  legalName    String?
  status       StoreStatus  @default(ACTIVE)

  phone    String?
  whatsapp String?

  addressLine   String?
  addressNumber String?
  neighborhood  String?
  city          String?
  state         String?
  zipCode       String?

  latitude  Decimal? @db.Decimal(9, 6)
  longitude Decimal? @db.Decimal(9, 6)

  isOpen Boolean @default(true)

  supportsDelivery Boolean @default(true)
  supportsPickup   Boolean @default(true)
  supportsDineIn   Boolean @default(false)

  deliveryRadiusKm Decimal? @db.Decimal(5, 2)
  deliveryFeeCents Int?

  trialEndsAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users          User[]
  categories     Category[]
  products       Product[]
  operatingHours StoreOperatingHour[]
  modifierGroups ModifierGroup[]
  orders         Order[]
}

/// =================
/// STORE StoreOperatingHour
/// =================

model StoreOperatingHour {
  id        String  @id @default(uuid())
  weekday   Weekday
  openTime  String
  closeTime String

  storeId String
  store   Store  @relation(fields: [storeId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([storeId])
  @@index([storeId, weekday])
}

/// =================
/// STORE user
/// =================
enum Role {
  OWNER
  STAFF
}

model User {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  passwordHash String
  role         Role
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  storeId              String
  store                Store                @relation(fields: [storeId], references: [id])
  orderStatusHistories OrderStatusHistory[]

  @@unique([email, storeId])
  @@index([storeId])
}

/// =================
/// STORE Menu
/// =================

model Category {
  id     String  @id @default(uuid())
  title  String
  active Boolean @default(true)

  displayOrder Int     @default(0)
  showInMenu   Boolean @default(true)
  showInPos    Boolean @default(false)
  showInWaiter Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  storeId String
  store   Store     @relation(fields: [storeId], references: [id], onDelete: Cascade)
  product Product[]

  @@unique([storeId, title])
  @@index([storeId])
  @@index([storeId, displayOrder])
}

model Product {
  id               String   @id @default(uuid())
  name             String
  price            Decimal  @db.Decimal(10, 2)
  description      String?
  image            String?
  promotionalPrice Decimal? @db.Decimal(10, 2)
  active           Boolean  @default(true)
  displayOrder     Int      @default(0)
  categoryId       String
  storeId          String
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  category       Category               @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  store          Store                  @relation(fields: [storeId], references: [id], onDelete: Cascade)
  modifierGroups ProductModifierGroup[]

  @@unique([storeId, categoryId, name])
  @@index([storeId])
  @@index([storeId, displayOrder])
}

model ModifierGroup {
  id            String   @id @default(uuid())
  name          String
  surname       String?
  active        Boolean  @default(true)
  required      Boolean  @default(false)
  minSelections Int      @default(0)
  maxSelections Int      @default(1)
  displayOrder  Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  storeId String
  store   Store  @relation(fields: [storeId], references: [id], onDelete: Cascade)

  options      ModifierOption[]
  productLinks ProductModifierGroup[]

  @@unique([storeId, surname])
  @@index([storeId])
  @@index([storeId, displayOrder])
}

model ModifierOption {
  id           String   @id @default(uuid())
  name         String
  description  String?
  image        String?
  price        Decimal  @default(0) @db.Decimal(10, 2)
  maxQuantity  Int?
  active       Boolean  @default(true)
  displayOrder Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  modifierGroupId String
  modifierGroup   ModifierGroup @relation(fields: [modifierGroupId], references: [id], onDelete: Cascade)

  @@index([modifierGroupId])
  @@index([modifierGroupId, displayOrder])
}

model ProductModifierGroup {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())

  productId       String
  modifierGroupId String

  product       Product       @relation(fields: [productId], references: [id], onDelete: Cascade)
  modifierGroup ModifierGroup @relation(fields: [modifierGroupId], references: [id], onDelete: Cascade)

  @@unique([productId, modifierGroupId])
  @@index([productId])
  @@index([modifierGroupId])
}

/// =================
/// STORE Orders
/// =================

enum ServiceType {
  DELIVERY
  PICKUP
  DINE_IN
}

enum OrderStatus {
  PENDING
  ACCEPTED
  IN_PREPARATION
  READY
  CANCELED
  FINISHED
}

enum PaymentMethod {
  PIX
  CASH
  CARD
  OTHER
}

model Order {
  id                    String               @id @default(uuid())
  storeId               String
  orderNumber           Int
  sequenceKey           String
  customerName          String?
  customerPhone         String?
  serviceType           ServiceType
  paymentMethod         PaymentMethod
  paymentDetail         String?
  status                OrderStatus          @default(PENDING)
  subtotal              Decimal
  deliveryFee           Decimal              @default(0)
  discount              Decimal              @default(0)
  couponCode            String?
  total                 Decimal
  noteOrder             String?
  cancellationReason    String?
  printedAt             DateTime?
  deliveryAddressLine   String?
  deliveryAddressNumber String?
  deliveryNeighborhood  String?
  deliveryCity          String?
  deliveryState         String?
  deliveryZipCode       String?
  deliveryComplement    String?
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt
  store                 Store                @relation(fields: [storeId], references: [id], onDelete: Cascade)
  orderItems            OrderItem[]
  orderStatusHistories  OrderStatusHistory[]

  @@unique([storeId, sequenceKey, orderNumber])
  @@index([storeId, createdAt])
  @@index([storeId, status, createdAt])
}

model OrderItem {
  id                  String                    @id @default(uuid())
  orderId             String
  productId           String
  productNameSnapshot String
  unitPrice           Decimal
  quantity            Int
  total               Decimal
  noteItem            String?
  order               Order                     @relation(fields: [orderId], references: [id], onDelete: Cascade)

  modifierGroups      OrderItemModifierGroup[]

  @@index([orderId])
  @@index([productId])
}

model OrderItemModifierGroup {
  id                String                      @id @default(uuid())
  orderItemId       String
  modifierGroupId   String?
  groupNameSnapshot String
  required          Boolean
  minSelections     Int
  maxSelections     Int
  displayOrder      Int?
  createdAt         DateTime                    @default(now())
  updatedAt         DateTime                    @updatedAt

  orderItem         OrderItem                   @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  options           OrderItemModifierOption[]

  @@index([orderItemId])
  @@index([modifierGroupId])
}

model OrderItemModifierOption {
  id                          String                      @id @default(uuid())
  orderItemModifierGroupId     String
  modifierOptionId             String?
  optionNameSnapshot           String
  optionPriceSnapshot          Decimal
  quantity                     Int                         @default(1)
  displayOrder                 Int?
  createdAt                    DateTime                    @default(now())
  updatedAt                    DateTime                    @updatedAt

  modifierGroup                OrderItemModifierGroup      @relation(fields: [orderItemModifierGroupId], references: [id], onDelete: Cascade)

  @@index([orderItemModifierGroupId])
  @@index([modifierOptionId])
}

model OrderStatusHistory {
  id        String      @id @default(uuid())
  orderId   String
  status    OrderStatus
  userId    String
  reason    String?
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId, createdAt])
}
